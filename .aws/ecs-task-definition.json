{
  "family": "vortex-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::123456789012:role/vortex-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::123456789012:role/vortex-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "vortex-api",
      "image": "123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/vortex-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vortex-api",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environment": [
        {
          "name": "PORT",
          "value": "3000"
        }
      ]
    }
  ]
}
